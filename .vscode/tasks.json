{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--workspace"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo test",
      "type": "shell",
      "command": "cargo",
      "args": ["test", "--workspace"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo clippy",
      "type": "shell",
      "command": "cargo",
      "args": ["clippy", "--workspace", "--", "-D", "warnings"],
      "group": "none",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo fmt",
      "type": "shell",
      "command": "cargo",
      "args": ["fmt", "--all"],
      "group": "none"
    },
    {
      "label": "cargo doc",
      "type": "shell",
      "command": "cargo",
      "args": ["doc", "--workspace", "--no-deps"],
      "group": "none"
    },
    {
      "label": "Run CLI",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--package", "clawdius", "--", "chat", "hello"],
      "group": "none",
      "dependsOn": ["cargo build"]
    },
    {
      "label": "Run TUI",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--package", "clawdius"],
      "group": "none",
      "dependsOn": ["cargo build"]
    },
    {
      "label": "Build WASM",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--target", "wasm32-unknown-unknown", "--package", "clawdius-webview"],
      "group": "none"
    },
    {
      "label": "Build VSCode Extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "options": {
        "cwd": "${workspaceFolder}/editors/vscode"
      },
      "group": "none"
    },
    {
      "label": "Full CI",
      "dependsOn": ["cargo fmt", "cargo clippy", "cargo test"],
      "group": "none"
    }
  ]
}
