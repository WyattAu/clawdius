{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug CLI",
      "cargo": {
        "args": ["build", "--bin=clawdius", "--package=clawdius"],
        "filter": {
          "name": "clawdius",
          "kind": "bin"
        }
      },
      "args": ["chat", "hello"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug TUI",
      "cargo": {
        "args": ["build", "--bin=clawdius", "--package=clawdius"],
        "filter": {
          "name": "clawdius",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Tests",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--package=clawdius-core"],
        "filter": {
          "kind": "lib"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug VSCode Helper",
      "cargo": {
        "args": ["build", "--bin=clawdius-code", "--package=clawdius-code"],
        "filter": {
          "name": "clawdius-code",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
