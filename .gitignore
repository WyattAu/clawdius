# =============================================================================
# Clawdius .gitignore
# Comprehensive ignore patterns for Rust, Nix, Docker, and development tools
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
debug/
**/*.rs.bk
*.pdb
Cargo.lock
**/mutants.out*/
*.rlib
*.rmeta
*.dSYM/
*.exe
*.exp
*.lib

# -----------------------------------------------------------------------------
# Environment Files (Secrets & Configuration)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/
.secrets/
credentials.json
service-account.json

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (IntelliJ, RustRover, CLion)
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*.swn
*~
.*.swp

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# Helix
.helix/

# Zed
zed/

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Build Artifacts & Outputs
# -----------------------------------------------------------------------------
/dist/
/build/
/out/
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.log

# -----------------------------------------------------------------------------
# Test Artifacts & Coverage
# -----------------------------------------------------------------------------
/coverage/
/.coverage/
*.profraw
*.profdata
lcov.info
coverage.xml
cobertura.xml
*.gcda
*.gcno
/test-results/
/.test-results/
junit.xml

# -----------------------------------------------------------------------------
# Documentation Builds
# -----------------------------------------------------------------------------
/doc/
/docs/_build/
/site/
/.docusaurus/
node_modules/

# -----------------------------------------------------------------------------
# Nix Files
# -----------------------------------------------------------------------------
/result
/result-*
/.direnv/
/.devenv/
devenv.local.nix
.pre-commit-config.yaml

# -----------------------------------------------------------------------------
# Docker Files
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Package Manager Caches
# -----------------------------------------------------------------------------

# Cargo
.cargo/registry/
.cargo/git/

# npm/yarn/pnpm (if used for tooling)
node_modules/
.npm
.yarn
.pnpm-debug.log

# -----------------------------------------------------------------------------
# Linting & Static Analysis
# -----------------------------------------------------------------------------
.clippy.toml
rustfmt.toml.bak

# -----------------------------------------------------------------------------
# Temporary & Cache Files
# -----------------------------------------------------------------------------
/tmp/
/temp/
.cache/
*.cache
*.tmp
*.temp
*.bak
*.backup
*.orig

# -----------------------------------------------------------------------------
# Logs & Databases
# -----------------------------------------------------------------------------
*.log
*.sql
*.sqlite
*.db
logs/

# -----------------------------------------------------------------------------
# Archive Files
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bz2
*.xz

# -----------------------------------------------------------------------------
# Clawdius Specific
# -----------------------------------------------------------------------------
/.reports/*.json
/.reports/*.html
/.knowledge_graph/cache/
/.clawdius/cache/
*.clawdius-session

# -----------------------------------------------------------------------------
# AI/LLM Cache Files
# -----------------------------------------------------------------------------
.claude/
.aider*
.cursor/
.continue/
.cody/
.clawdius/config.toml
