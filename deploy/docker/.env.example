# Clawdius Docker Compose Environment Configuration
# Copy this file to .env and adjust values as needed

# ===========================================
# Clawdius Server Configuration
# ===========================================

# Version tag for Clawdius image
CLAWDIUS_VERSION=latest

# Port to expose Clawdius server
CLAWDIUS_PORT=3000

# Resource limits for Clawdius container
CLAWDIUS_CPUS=2
CLAWDIUS_MEMORY=2G

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# Host directory containing projects to mount (read-only)
HOST_PROJECTS=./projects

# ===========================================
# Ollama Configuration (Local LLM)
# ===========================================

# Ollama version
OLLAMA_VERSION=latest

# Ollama port
OLLAMA_PORT=11434

# Default model to use (pull with: docker exec clawdius-ollama ollama pull <model>)
# Recommended models:
# - deepseek-coder:6.7b (fast, good for code)
# - codellama:7b (general purpose)
# - mistral:7b (balanced)
# - llama3:8b (latest Llama)

# ===========================================
# Redis Cache (Optional - enable with --profile cache)
# ===========================================

REDIS_PORT=6379

# ===========================================
# Prometheus Monitoring (Optional - enable with --profile monitoring)
# ===========================================

PROMETHEUS_VERSION=latest
PROMETHEUS_PORT=9090

# ===========================================
# Grafana Visualization (Optional - enable with --profile monitoring)
# ===========================================

GRAFANA_VERSION=latest
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ===========================================
# Security Settings
# ===========================================

# JWT secret for authentication (generate with: openssl rand -hex 32)
# CLAWDIUS_JWT_SECRET=your-secret-key-here

# ===========================================
# LLM API Keys (Optional - for cloud providers)
# ===========================================

# OpenAI API key
# OPENAI_API_KEY=sk-...

# Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# SSO Configuration (Optional - for enterprise)
# ===========================================

# OIDC client secret (when using SSO)
# OIDC_CLIENT_SECRET=your-oidc-secret
