# Clawdius Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Provider API Keys
# ===========================================

# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Ollama (local) - no key required, set base URL if non-default
# OLLAMA_BASE_URL=http://localhost:11434

# Z.AI (Zhipu AI) - https://open.bigmodel.cn
ZAI_API_KEY=your-zai-key-here

# OpenRouter (multi-provider) - https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ===========================================
# Optional Features
# ===========================================

# JWT secret for authentication (generate: openssl rand -hex 32)
# CLAWDIUS_JWT_SECRET=your-secret-key-here

# Log level (trace, debug, info, warn, error)
RUST_LOG=info
