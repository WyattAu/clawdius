# Clawdius Automatic Environment Loader
# Requires: direnv (https://direnv.net)

# Ensure the nix environment is used
use flake

# Security: Sentinel pathing
# Add podman/bwrap to path if they aren't globally available
export CLAWDIUS_SANDBOX_BACKEND="bubblewrap"

# Architecture: Deterministic Build Flags
export RUSTFLAGS="-C target-cpu=native"

# Logic: LLM Provider Configuration (Optional template)
# export ANTHROPIC_API_KEY="your-key-here"
# export OPENAI_API_KEY="your-key-here"

# Notification Hook
if [ -f .clawdius/sentinel/capabilities.toml ]; then
    echo "🛡️ Sentinel Whitelist Loaded"
fi